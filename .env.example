# Copy to .env or .env.local — never commit secrets

# Local Docker (default for capstone dev — see docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/cfo_capstone

# Production (Neon): use pooled URL with -pooler host — see docs/vercel-deploy.md
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# LLM provider: google (default for now) | openai | anthropic
LLM_PROVIDER=google
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google defaults (switch LLM_PROVIDER=openai + OPENAI_API_KEY when ready)
LLM_MODEL=gemini-2.0-flash
LLM_MODEL_AP=gemini-2.0-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# OpenAI alternatives (when LLM_PROVIDER=openai)
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

TAG_AUTO_THRESHOLD=0.92
TAG_REVIEW_THRESHOLD=0.75

# Eval determinism — set false in CI for golden replay without live API calls
LLM_ENABLE_LIVE_CALLS=true
LLM_MAX_RETRIES=3

# Optional observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
