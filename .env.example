# Copy to .env or .env.local — never commit secrets

# Local Docker (see docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/cfo_capstone

# Production (Neon): use pooled URL with -pooler host — see docs/vercel-deploy.md
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# LLM provider: google (default for now) | openai | anthropic
LLM_PROVIDER=google
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google defaults (switch LLM_PROVIDER=openai + OPENAI_API_KEY when ready)
LLM_MODEL=gemini-2.5-flash
LLM_MODEL_AP=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# OpenAI alternatives (when LLM_PROVIDER=openai)
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

TAG_AUTO_THRESHOLD=0.92
TAG_REVIEW_THRESHOLD=0.75

# Eval determinism — set false in CI for golden replay without live API calls
LLM_ENABLE_LIVE_CALLS=true
LLM_MAX_RETRIES=3

# Optional observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# LangGraph orchestrator
AUTO_TAG_HITL_ENABLED=false
LANGGRAPH_CHECKPOINTER=postgres

# API auth — MUST be true for public production (see pnpm production:check)
REQUIRE_API_AUTH=false

# Rate limits (requests per 60s window, per serverless instance)
RATE_LIMIT_INGEST_PER_MIN=60
RATE_LIMIT_WEBHOOK_PER_MIN=120
RATE_LIMIT_API_PER_MIN=300

# Runtime (set by Vercel automatically)
# NODE_ENV=production
# VERCEL_ENV=production

# Webhook ingest (Phase 2) — replay window for X-Recon-Signature timestamps
WEBHOOK_SIGNATURE_TOLERANCE_SEC=300
# Local demo: whsec_… from pnpm db:seed
# WEBHOOK_DEMO_SECRET=
# WEBHOOK_DEMO_BASE_URL=http://localhost:3000
# WEBHOOK_DEMO_TENANT_SLUG=tenant-a

# ERP integration (mock | quickbooks_sandbox | xero_sandbox — latter two use mock until OAuth ships)
ERP_PROVIDER=mock
