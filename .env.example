# Copy to .env or .env.local — never commit secrets

# Local Docker (see docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/cfo_capstone
# RLS in dev: migrations create role recon_app; scoped txs use SET LOCAL ROLE recon_app
# RLS_USE_APP_ROLE=false  # skip SET ROLE (Neon non-superuser URLs)

# Production (Neon): use pooled URL with -pooler host — see docs/vercel-deploy.md
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# LLM provider: google (default for now) | openai | anthropic
LLM_PROVIDER=google
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google defaults (switch LLM_PROVIDER=openai + OPENAI_API_KEY when ready)
LLM_MODEL=gemini-2.5-flash
LLM_MODEL_AP=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# OpenAI alternatives (when LLM_PROVIDER=openai)
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

TAG_AUTO_THRESHOLD=0.92
TAG_REVIEW_THRESHOLD=0.75

# Eval determinism — set false in CI for golden replay without live API calls
LLM_ENABLE_LIVE_CALLS=true
LLM_MAX_RETRIES=3

# Optional observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# LangGraph orchestrator
AUTO_TAG_HITL_ENABLED=false
LANGGRAPH_CHECKPOINTER=postgres

# Ingest: when true, POST /api/ingest/transactions returns 202 unless ?async=false
# Per-request override: ?async=true|false or header Prefer: respond-async
INGEST_ASYNC_DEFAULT=false

# Webhooks default to async 202 unless ?async=false
WEBHOOK_ASYNC_DEFAULT=true

# Async processing worker (POST /api/cron/process-pending-transactions)
# CRON_SECRET=
# PROCESSING_MAX_ATTEMPTS=3

# API auth — MUST be true for public production (see pnpm production:check)
REQUIRE_API_AUTH=false

# Settings UI — webhook + ERP panels (default hidden for showcase / prod demo)
SETTINGS_SHOW_INTEGRATIONS=false

# SSO (Clerk) — optional; when set, UI requires sign-in and tenants come from memberships
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# After first sign-in: CLERK_SEED_USER_ID=user_xxx pnpm auth:seed-memberships

# Rate limits (requests per 60s window, per serverless instance)
RATE_LIMIT_INGEST_PER_MIN=60
RATE_LIMIT_WEBHOOK_PER_MIN=120
RATE_LIMIT_API_PER_MIN=300

# Runtime (set by Vercel automatically)
# NODE_ENV=production
# VERCEL_ENV=production

# Webhook ingest (Phase 2) — replay window for X-Recon-Signature timestamps
WEBHOOK_SIGNATURE_TOLERANCE_SEC=300
# Local demo: whsec_… from pnpm db:seed
# WEBHOOK_DEMO_SECRET=
# WEBHOOK_DEMO_BASE_URL=http://localhost:3000
# WEBHOOK_DEMO_TENANT_SLUG=tenant-a

# ERP integration (mock | quickbooks_sandbox | xero_sandbox)
ERP_PROVIDER=quickbooks_sandbox

# QuickBooks sandbox OAuth (https://developer.intuit.com)
# Redirect URI must match app settings, e.g. http://localhost:3000/api/erp/callback/quickbooks
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/erp/callback/quickbooks
# Credit side for card-txn journal entries (QBO Account Id or GL code via AcctNum/Name lookup)
# QUICKBOOKS_OFFSET_ACCOUNT_ID=
# QUICKBOOKS_OFFSET_GL_CODE=2100
# QUICKBOOKS_JOURNAL_STUB=true   # skip real QBO write; synthetic external id (local only)

# Receipt chase (mock — records ReceiptChaseSent events + audit)
# RECEIPT_CHASE_CHANNEL=mock_email
# RECEIPT_CHASE_CHANNEL=mock_slack
# RECEIPT_CHASE_CHANNEL=off

# AP cash forecast mock balance (USD)
# AP_AVAILABLE_CASH_USD=50000
