{
  "name": "recon-ai",
  "version": "0.1.0",
  "description": "Event-driven CFO platform — orchestrated tagging, policy, and AP with audit and MCP",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:import-data": "tsx scripts/import-external-data.ts",
    "eval:tagging": "tsx scripts/run-tagging-eval.ts",
    "eval:gate": "tsx scripts/eval-gate.ts",
    "demo": "tsx scripts/demo.ts",
    "ingest:rag-demo": "tsx scripts/ingest-rag-demo.ts",
    "webhook:demo": "tsx scripts/webhook-demo.ts",
    "verify": "tsx scripts/verify-showcase.ts",
    "verify:full": "tsx scripts/verify-showcase.ts && pnpm demo",
    "showcase:prep": "tsx scripts/showcase-prep.ts",
    "showcase": "tsx scripts/showcase-prep.ts && pnpm demo",
    "eval:results-doc": "tsx scripts/update-eval-results-doc.ts",
    "production:check": "tsx scripts/production-check.ts",
    "auth:print-hints": "tsx scripts/print-dev-credentials.ts",
    "auth:reset-keys": "tsx scripts/reset-dev-api-keys.ts",
    "auth:seed-memberships": "tsx scripts/seed-memberships.ts",
    "mcp": "tsx src/mcp/server.ts",
    "graph:diagram": "tsx scripts/export-graph-diagram.ts",
    "db:setup-checkpointer": "tsx scripts/setup-langgraph-checkpointer.ts",
    "test": "LANGGRAPH_CHECKPOINTER=memory AUTO_TAG_HITL_ENABLED=false node --import tsx --test tests/unit/**/*.test.ts tests/integration/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "playwright:install": "playwright install chromium",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.3",
    "@google/generative-ai": "^0.24.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.3",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.2",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "drizzle-orm": "^0.39.3",
    "langfuse": "^3.38.20",
    "mermaid": "^11.15.0",
    "next": "^15.1.0",
    "openai": "^4.77.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.51.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.99.0"
  }
}
